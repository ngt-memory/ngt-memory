# NGT Memory API — configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Optional: protect API with a secret key ───────────────────────────────────
# If set — all requests require header: X-Api-Key: <value>
# Leave empty for open access (single-user or trusted network)
NGT_API_SECRET=

# ── OpenAI models ─────────────────────────────────────────────────────────────
NGT_CHAT_MODEL=gpt-4.1-nano
NGT_EMBEDDING_MODEL=text-embedding-3-small

# ── Memory settings ───────────────────────────────────────────────────────────
NGT_MEMORY_TOP_K=5          # memories injected per turn
NGT_MEMORY_THRESHOLD=0.25   # min cosine score to include a memory (0.0-1.0)
NGT_USE_GRAPH=true          # enable graph-boosted retrieval (recommended)

# ── Session settings ──────────────────────────────────────────────────────────
NGT_SESSION_TTL=3600        # session inactivity timeout in seconds
NGT_MAX_SESSIONS=100        # max concurrent sessions

# ── Server ────────────────────────────────────────────────────────────────────
# NGT_ROOT_PATH=/api       # set if behind reverse proxy (e.g. nginx → /api)

# ── CORS ──────────────────────────────────────────────────────────────────────
NGT_CORS_ORIGINS=*          # allowed origins, comma-separated
