# NGT Memory API — конфигурация
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env

# ── Обязательно ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Опционально: защита API ключом ───────────────────────────────────────────
# Если установлен — все запросы требуют заголовок: X-Api-Key: <значение>
# Оставьте пустым для открытого доступа (только для локальной разработки)
NGT_API_SECRET=

# ── Модели OpenAI ─────────────────────────────────────────────────────────────
NGT_CHAT_MODEL=gpt-5-nano
NGT_EMBEDDING_MODEL=text-embedding-3-small

# ── Настройки памяти ──────────────────────────────────────────────────────────
NGT_MEMORY_TOP_K=5          # сколько воспоминаний инжектировать в контекст
NGT_MEMORY_THRESHOLD=0.25   # минимальный cosine score (0.0 - 1.0)
NGT_USE_GRAPH=true          # использовать граф ассоциаций (рекомендуется)

# ── Управление сессиями ───────────────────────────────────────────────────────
NGT_SESSION_TTL=3600        # время жизни неактивной сессии (секунды)
NGT_MAX_SESSIONS=100        # максимум одновременных сессий

# ── Billing (Stripe) ────────────────────────────────────────────────────────
# Включить billing: API-ключи + тарифы + rate limits
# false = открытый доступ (для локальной разработки)
NGT_BILLING_ENABLED=false

# Stripe ключи (из https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (из Products → Pricing)
STRIPE_PRICE_FREE=price_free
STRIPE_PRICE_PRO=price_pro
STRIPE_PRICE_ENTERPRISE=price_enterprise
