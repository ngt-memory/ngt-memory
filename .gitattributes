# Normalize line endings
* text=auto

# Python files — LF
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.env.example text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pt binary
*.pth binary
*.pkl binary
*.zip binary
*.tar.gz binary
